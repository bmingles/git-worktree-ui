astingForeground(bgColor string) string {\n    46â†’\t// Remove # if present\n    47â†’\tbgColor = strings.TrimPrefix(bgColor, \"#\")\n    48â†’\t\n    49â†’\t// Parse RGB components\n    50â†’\tif len(bgColor) != 6 {\n    51â†’\t\treturn \"#ffffff\" // Default to white if invalid\n    52â†’\t}\n    53â†’\t\n    54â†’\tr, err1 := strconv.ParseInt(bgColor[0:2], 16, 64)\n    55â†’\tg, err2 := strconv.ParseInt(bgColor[2:4], 16, 64)\n    56â†’\tb, err3 := strconv.ParseInt(bgColor[4:6], 16, 64)\n    57â†’\t\n    58â†’\tif err1 != nil || err2 != nil || err3 != nil {\n    59â†’\t\treturn \"#ffffff\"\n    60â†’\t}\n    61â†’\t\n    62â†’\t// Calculate relative luminance using sRGB colorspace\n    63â†’\t// Formula: L = 0.2126 * R + 0.7152 * G + 0.0722 * B\n    64â†’\tluminance := (0.2126 * float64(r)) + (0.7152 * float64(g)) + (0.0722 * float64(b))\n    65â†’\t\n    66â†’\t// Use threshold of 128 (middle of 0-255 range)\n    67â†’\t// Light backgrounds get black text, dark backgrounds get white text\n    68â†’\tif luminance > 128 {\n    69â†’\t\treturn \"#000000\"\n    70â†’\t}\n    71â†’\treturn \"#ffffff\"\n    72â†’}\n    73â†’\n    74â†’// AdjustColorBrightness adjusts the brightness of a color by a percentage.\n    75â†’// Positive percentage makes it lighter, negative makes it darker.\n    76â†’func AdjustColorBrightness(hexColor string, percentage float64) string {\n    77â†’\thexColor = strings.TrimPrefix(hexColor, \"#\")\n    78â†’\t\n    79â†’\tif len(hexColor) != 6 {\n    80â†’\t\treturn hexColor\n    81â†’\t}\n    82â†’\t\n    83â†’\tr, _ := strconv.ParseInt(hexColor[0:2], 16, 64)\n    84â†’\tg, _ := strconv.ParseInt(hexColor[2:4], 16, 64)\n    85â†’\tb, _ := strconv.ParseInt(hexColor[4:6], 16, 64)\n    86â†’\t\n    87â†’\tfactor := 1.0 + (percentage / 100.0)\n    88â†’\t\n    89â†’\tr = int64(float64(r) * factor)\n    90â†’\tg = int64(float64(g) * factor)\n    91â†’\tb = int64(float64(b) * factor)\n    92â†’\t\n    93â†’\t// Clamp values to 0-255\n    94â†’\tif r > 255 { r = 255 }\n    95â†’\tif r < 0 { r = 0 }\n    96â†’\tif g > 255 { g = 255 }\n    97â†’\tif g < 0 { g = 0 }\n    98â†’\tif b > 255 { b = 255 }\n    99â†’\tif b < 0 { b = 0 }\n   100â†’\t\n   101â†’\treturn fmt.Sprintf(\"%02x%02x%02x\", r, g, b)\n   102â†’}\n   103â†’\n   104â†’// GetPrimaryProjectPath returns the primary project path (the main repository path).\n   105â†’// If the given path is a worktree, it returns the path of the primary worktree.\n   106â†’// Otherwise, it returns the path itself.\n   107â†’func GetPrimaryProjectPath(path string) (string, error) {\n   108â†’\t// Try to get git worktree list\n   109â†’\tcmd := exec.Command(\"git\", \"worktree\", \"list\", \"--porcelain\")\n   110â†’\tcmd.Dir = path\n   111â†’\t\n   112â†’\toutput, err := cmd.CombinedOutput()\n   113â†’\tif err != nil {\n   114â†’\t\t// Not a git repository or worktree, return the path itself\n   115â†’\t\treturn path, nil\n   116â†’\t}\n   117â†’\t\n   118â†’\t// Parse the output to find the primary worktree (first one listed)\n   119â†’\tlines := strings.Split(string(output), \"\\n\")\n   120â†’\tfor _, line := range lines {\n   121â†’\t\tif strings.HasPrefix(line, \"worktree \") {\n   122â†’\t\t\tprimaryPath := strings.TrimPrefix(line, \"worktree \")\n   123â†’\t\t\treturn primaryPath, nil\n   124â†’\t\t}\n   125â†’\t}\n   126â†’\t\n   127â†’\t// If we can't determine, return the original path\n   128â†’\treturn path, nil\n   129â†’}\n   130â†’\n   131â†’// WorkspaceFileExists checks if a workspace file already exists for the given path.\n   132â†’func WorkspaceFileExists(targetPath string) bool {\n   133â†’\t// Get the primary project path for consistent naming\n   134â†’\tprimaryPath, err := GetPrimaryProjectPath(targetPath)\n   135â†’\tif err != nil {\n   136â†’\t\tprimaryPath = targetPath\n   137â†’\t}\n   138â†’\t\n   139â†’\t// Get the base name for the workspace file\n   140â†’\tbaseName := filepath.Base(primaryPath)\n   141â†’\tworkspaceFileName := fmt.Sprintf(\"%s.local.code-workspace\", baseName)\n   142â†’\tworkspaceFilePath := filepath.Join(targetPath, workspaceFileName)\n   143â†’\t\n   144â†’\t// Check if file exists\n   145â†’\t_, err = os.Stat(workspaceFilePath)\n   146â†’\treturn err == nil\n   147â†’}\n   148â†’\n   149â†’// CreateWorkspaceFile creates a .code-workspace file in the specified directory\n   150â†’// with color customizations based on the primary project path.\n   151â†’func CreateWorkspaceFile(targetPath string) error {\n   152â†’\t// Get the primary project path for consistent coloring\n   153â†’\tprimaryPath, err := GetPrimaryProjectPath(targetPath)\n   154â†’\tif err != nil {\n   155â†’\t\tprimaryPath = targetPath\n   156â†’\t}\n   157â†’\t\n   158â†’\t// Get the base name for the workspace file\n   159â†’\tbaseName := filepath.Base(primaryPath)\n   160â†’\tworkspaceFileName := fmt.Sprintf(\"%s.local.code-workspace\", baseName)\n   161â†’\tworkspaceFilePath := filepath.Join(targetPath, workspaceFileName)\n   162â†’\t\n   163â†’\t// Check if file already exists\n   164â†’\tif _, err := os.Stat(workspaceFilePath); err == nil {\n   165â†’\t\treturn fmt.Errorf(\"workspace file already exists: %s\", workspaceFilePath)\n   166â†’\t}\n   167â†’\t\n   168â†’\t// Generate color based on primary path\n   169â†’\tbaseColor := GenerateColorFromPath(primaryPath)\n   170â†’\tforegroundColor := GetContrastingForeground(baseColor)\n   171â†’\tinactiveColor := AdjustColorBrightness(baseColor, -15) // Slightly darker for inactive\n   172â†’\t\n   173â†’\t// Create workspace structure\n   174â†’\tworkspace := WorkspaceFile{\n   175â†’\t\tFolders: []WorkspaceFolder{\n   176â†’\t\t\t{Path: \".\"},\n   177â†’\t\t},\n   178â†’\t\tSettings: map[string]interface{}{\n   179â†’\t\t\t\"workbench.colorCustomizations\": map[string]string{\n   180â†’\t\t\t\t\"statusBar.background\":        \"#\" + baseColor,\n   181â†’\t\t\t\t\"statusBar.foreground\":        foregroundColor,\n   182â†’\t\t\t\t\"titleBar.activeBackground\":   \"#\" + baseColor,\n   183â†’\t\t\t\t\"titleBar.activeForeground\":   foregroundColor,\n   184â†’\t\t\t\t\"titleBar.inactiveBackground\": \"#\" + inactiveColor,\n   185â†’\t\t\t},\n   186â†’\t\t},\n   187â†’\t}\n   188â†’\t\n   189â†’\t// Marshal to JSON with indentation\n   190â†’\tdata, err := json.MarshalIndent(workspace, \"\", \"  \")\n   191â†’\tif err != nil {\n   192â†’\t\treturn fmt.Errorf(\"failed to marshal workspace file: %w\", err)\n   193â†’\t}\n   194â†’\t\n   195â†’\t// Write to file\n   196â†’\tif err := os.WriteFile(workspaceFilePath, data, 0644); err != nil {\n   197â†’\t\treturn fmt.Errorf(\"failed to write workspace file: %w\", err)\n   198â†’\t}\n   199â†’\t\n   200â†’\treturn nil\n   201â†’}\n   202â†’\n   203â†’// IsWorktree checks if the given path is a worktree (not the primary repository).\n   204â†’// Returns true if it's a worktree, false if it's the primary or not a git repo.\n   205â†’func IsWorktree(path string) bool {\n   206â†’\tcmd := exec.Command(\"git\", \"rev-parse\", \"--git-dir\")\n   207â†’\tcmd.Dir = path\n   208â†’\t\n   209â†’\toutput, err := cmd.CombinedOutput()\n   210â†’\tif err != nil {\n   211â†’\t\treturn false\n   212â†’\t}\n   213â†’\t\n   214â†’\tgitDir := strings.TrimSpace(string(output))\n   215â†’\t// Worktrees have .git as a file (containing path to actual git dir)\n   216â†’\t// Primary repo has .git as a directory\n   217â†’\treturn !strings.HasSuffix(gitDir, \".git\")\n   218â†’}\n   219â†’\n   220â†’// GetWorkspaceFilePath returns the expected workspace file path for a given directory.\n   221â†’func GetWorkspaceFilePath(targetPath string) (string, error) {\n   222â†’\tprimaryPath, err := GetPrimaryProjectPath(targetPath)\n   223â†’\tif err != nil {\n   224â†’\t\tprimaryPath = targetPath\n   225â†’\t}\n   226â†’\t\n   227â†’\tbaseName := filepath.Base(primaryPath)\n   228â†’\tworkspaceFileName := fmt.Sprintf(\"%s.local.code-workspace\", baseName)\n   229â†’\treturn filepath.Join(targetPath, workspaceFileName), nil\n   230â†’}\n   231â†’\n   232â†’// CopyWorkspaceFile copies a workspace file from the primary project to a worktree.\n   233â†’func CopyWorkspaceFile(primaryPath, worktreePath string) error {\n   234â†’\t// Get source workspace file from primary\n   235â†’\tsrcPath, err := GetWorkspaceFilePath(primaryPath)\n   236â†’\tif err != nil {\n   237â†’\t\treturn fmt.Errorf(\"failed to get primary workspace path: %w\", err)\n   238â†’\t}\n   239â†’\t\n   240â†’\t// Check if source exists\n   241â†’\tif _, err := os.Stat(srcPath); os.IsNotExist(err) {\n   242â†’\t\treturn fmt.Errorf(\"workspace file does not exist in primary: %s\", srcPath)\n   243â†’\t}\n   244â†’\t\n   245â†’\t// Get destination workspace file path\n   246â†’\tdstPath, err := GetWorkspaceFilePath(worktreePath)\n   247â†’\tif err != nil {\n   248â†’\t\treturn fmt.Errorf(\"failed to get worktree workspace path: %w\", err)\n   249â†’\t}\n   250â†’\t\n   251â†’\t// Read source file\n   252â†’\tdata, err := os.ReadFile(srcPath)\n   253â†’\tif err != nil {\n   254â†’\t\treturn fmt.Errorf(\"failed to read workspace file: %w\", err)\n   255â†’\t}\n   256â†’\t\n   257â†’\t// Write to destination\n   258â†’\tif err := os.WriteFile(dstPath, data, 0644); err != nil {\n   259â†’\t\treturn fmt.Errorf(\"failed to write workspace file: %w\", err)\n   260â†’\t}\n   261â†’\t\n   262â†’\treturn nil\n   263â†’}\n   264â†’\n   265â†’// CreateOrCopyWorkspaceFile creates or copies a workspace file based on context:\n   266â†’// - For primary branch: creates file if it doesn't exist, skips if it does\n   267â†’// - For worktrees: copies from primary if one exists, otherwise creates new, skips if already exists\n   268â†’func CreateOrCopyWorkspaceFile(targetPath string) error {\n   269â†’\t// Check if workspace file already exists\n   270â†’\tif WorkspaceFileExists(targetPath) {\n   271â†’\t\t// File exists, skip\n   272â†’\t\treturn nil\n   273â†’\t}\n   274â†’\t\n   275â†’\t// Check if this is a worktree\n   276â†’\tif