or = strings.TrimPrefix(bgColor, \"#\")\n    48→\t\n    49→\t// Parse RGB components\n    50→\tif len(bgColor) != 6 {\n    51→\t\treturn \"#ffffff\" // Default to white if invalid\n    52→\t}\n    53→\t\n    54→\tr, err1 := strconv.ParseInt(bgColor[0:2], 16, 64)\n    55→\tg, err2 := strconv.ParseInt(bgColor[2:4], 16, 64)\n    56→\tb, err3 := strconv.ParseInt(bgColor[4:6], 16, 64)\n    57→\t\n    58→\tif err1 != nil || err2 != nil || err3 != nil {\n    59→\t\treturn \"#ffffff\"\n    60→\t}\n    61→\t\n    62→\t// Calculate relative luminance using sRGB colorspace\n    63→\t// Formula: L = 0.2126 * R + 0.7152 * G + 0.0722 * B\n    64→\tluminance := (0.2126 * float64(r)) + (0.7152 * float64(g)) + (0.0722 * float64(b))\n    65→\t\n    66→\t// Use threshold of 128 (middle of 0-255 range)\n    67→\t// Light backgrounds get black text, dark backgrounds get white text\n    68→\tif luminance > 128 {\n    69→\t\treturn \"#000000\"\n    70→\t}\n    71→\treturn \"#ffffff\"\n    72→}\n    73→\n    74→// AdjustColorBrightness adjusts the brightness of a color by a percentage.\n    75→// Positive percentage makes it lighter, negative makes it darker.\n    76→func AdjustColorBrightness(hexColor string, percentage float64) string {\n    77→\thexColor = strings.TrimPrefix(hexColor, \"#\")\n    78→\t\n    79→\tif len(hexColor) != 6 {\n    80→\t\treturn hexColor\n    81→\t}\n    82→\t\n    83→\tr, _ := strconv.ParseInt(hexColor[0:2], 16, 64)\n    84→\tg, _ := strconv.ParseInt(hexColor[2:4], 16, 64)\n    85→\tb, _ := strconv.ParseInt(hexColor[4:6], 16, 64)\n    86→\t\n    87→\tfactor := 1.0 + (percentage / 100.0)\n    88→\t\n    89→\tr = int64(float64(r) * factor)\n    90→\tg = int64(float64(g) * factor)\n    91→\tb = int64(float64(b) * factor)\n    92→\t\n    93→\t// Clamp values to 0-255\n    94→\tif r > 255 { r = 255 }\n    95→\tif r < 0 { r = 0 }\n    96→\tif g > 255 { g = 255 }\n    97→\tif g < 0 { g = 0 }\n    98→\tif b > 255 { b = 255 }\n    99→\tif b < 0 { b = 0 }\n   100→\t\n   101→\treturn fmt.Sprintf(\"%02x%02x%02x\", r, g, b)\n   102→}\n   103→\n   104→// GetPrimaryProjectPath returns the primary project path (the main repository path).\n   105→// If the given path is a worktree, it returns the path of the primary worktree.\n   106→// Otherwise, it returns the path itself.\n   107→func GetPrimaryProjectPath(path string) (string, error) {\n   108→\t// Try to get git worktree list\n   109→\tcmd := exec.Command(\"git\", \"worktree\", \"list\", \"--porcelain\")\n   110→\tcmd.Dir = path\n   111→\t\n   112→\toutput, err := cmd.CombinedOutput()\n   113→\tif err != nil {\n   114→\t\t// Not a git repository or worktree, return the path itself\n   115→\t\treturn path, nil\n   116→\t}\n   117→\t\n   118→\t// Parse the output to find the primary worktree (first one listed)\n   119→\tlines := strings.Split(string(output), \"\\n\")\n   120→\tfor _, line := range lines {\n   121→\t\tif strings.HasPrefix(line, \"worktree \") {\n   122→\t\t\tprimaryPath := strings.TrimPrefix(line, \"worktree \")\n   123→\t\t\treturn primaryPath, nil\n   124→\t\t}\n   125→\t}\n   126→\t\n   127→\t// If we can't determine, return the original path\n   128→\treturn path, nil\n   129→}\n   130→\n   131→// WorkspaceFileExists checks if a workspace file already exists for the given path.\n   132→func WorkspaceFileExists(targetPath string) bool {\n   133→\t// Get the primary project path for consistent naming\n   134→\tprimaryPath, err := GetPrimaryProjectPath(targetPath)\n   135→\tif err != nil {\n   136→\t\tprimaryPath = targetPath\n   137→\t}\n   138→\t\n   139→\t// Get the base name for the workspace file\n   140→\tbaseName := filepath.Base(primaryPath)\n   141→\tworkspaceFileName := fmt.Sprintf(\"%s.local.code-workspace\", baseName)\n   142→\tworkspaceFilePath := filepath.Join(targetPath, workspaceFileName)\n   143→\t\n   144→\t// Check if file exists\n   145→\t_, err = os.Stat(workspaceFilePath)\n   146→\treturn err == nil\n   147→}\n   148→\n   149→// CreateWorkspaceFile creates a .code-workspace file in the specified directory\n   150→// with color customizations based on the primary project path.\n   151→func CreateWorkspaceFile(targetPath string) error {\n   152→\t// Get the primary project path for consistent coloring\n   153→\tprimaryPath, err := GetPrimaryProjectPath(targetPath)\n   154→\tif err != nil {\n   155→\t\tprimaryPath = targetPath\n   156→\t}\n   157→\t\n   158→\t// Get the base name for the workspace file\n   159→\tbaseName := filepath.Base(primaryPath)\n   160→\tworkspaceFileName := fmt.Sprintf(\"%s.local.code-workspace\", baseName)\n   161→\tworkspaceFilePath := filepath.Join(targetPath, workspaceFileName)\n   162→\t\n   163→\t// Check if file already exists\n   164→\tif _, err := os.Stat(workspaceFilePath); err == nil {\n   165→\t\treturn fmt.Errorf(\"workspace file already exists: %s\", workspaceFilePath)\n   166→\t}\n   167→\t\n   168→\t// Generate color based on primary path\n   169→\tbaseColor := GenerateColorFromPath(primaryPath)\n   170→\tforegroundColor := GetContrastingForeground(baseColor)\n   171→\tinactiveColor := AdjustColorBrightness(baseColor, -15) // Slightly darker for inactive\n   172→\t\n   173→\t// Create workspace structure\n   174→\tworkspace := WorkspaceFile{\n   175→\t\tFolders: []WorkspaceFolder{\n   176→\t\t\t{Path: \".\"},\n   177→\t\t},\n   178→\t\tSettings: map[string]interface{}{\n   179→\t\t\t\"workbench.colorCustomizations\": map[string]string{\n   180→\t\t\t\t\"statusBar.background\":        \"#\" + baseColor,\n   181→\t\t\t\t\"statusBar.foreground\":        foregroundColor,\n   182→\t\t\t\t\"titleBar.activeBackground\":   \"#\" + baseColor,\n   183→\t\t\t\t\"titleBar.activeForeground\":   foregroundColor,\n   184→\t\t\t\t\"titleBar.inactiveBackground\": \"#\" + inactiveColor,\n   185→\t\t\t},\n   186→\t\t},\n   187→\t}\n   188→\t\n   189→\t// Marshal to JSON with indentation\n   190→\tdata, err := json.MarshalIndent(workspace, \"\", \"  \")\n   191→\tif err != nil {\n   192→\t\treturn fmt.Errorf(\"failed to marshal workspace file: %w\", err)\n   193→\t}\n   194→\t\n   195→\t// Write to file\n   196→\tif err := os.WriteFile(workspaceFilePath, data, 0644); err != nil {\n   197→\t\treturn fmt.Errorf(\"failed to write workspace file: %w\", err)\n   198→\t}\n   199→\t\n   200→\treturn nil\n   201→}\n   202→\n   203→// IsWorktree checks if the given path is a worktree (not the primary repository).\n   204→// Returns true if it's a worktree, false if it's the primary or not a git repo.\n   205→func IsWorktree(path string) bool {\n   206→\tcmd := exec.Command(\"git\", \"rev-parse\", \"--git-dir\")\n   207→\tcmd.Dir = path\n   208→\t\n   209→\toutput, err := cmd.CombinedOutput()\n   210→\tif err != nil {\n   211→\t\treturn false\n   212→\t}\n   213→\t\n   214→\tgitDir := strings.TrimSpace(string(output))\n   215→\t// Worktrees have .git as a file (containing path to actual git dir)\n   216→\t// Primary repo has .git as a directory\n   217→\treturn !strings.HasSuffix(gitDir, \".git\")\n   218→}\n   219→\n   220→// GetWorkspaceFilePath returns the expected workspace file path for a given directory.\n   221→func GetWorkspaceFilePath(targetPath string) (string, error) {\n   222→\tprimaryPath, err := GetPrimaryProjectPath(targetPath)\n   223→\tif err != nil {\n   224→\t\tprimaryPath = targetPath\n   225→\t}\n   226→\t\n   227→\tbaseName := filepath.Base(primaryPath)\n   228→\tworkspaceFileName := fmt.Sprintf(\"%s.local.code-workspace\", baseName)\n   229→\treturn filepath.Join(targetPath, workspaceFileName), nil\n   230→}\n   231→\n   232→// CopyWorkspaceFile copies a workspace file from the primary project to a worktree.\n   233→func CopyWorkspaceFile(primaryPath, worktreePath string) error {\n   234→\t// Get source workspace file from primary\n   235→\tsrcPath, err := GetWorkspaceFilePath(primaryPath)\n   236→\tif err != nil {\n   237→\t\treturn fmt.Errorf(\"failed to get primary workspace path: %w\", err)\n   238→\t}\n   239→\t\n   240→\t// Check if