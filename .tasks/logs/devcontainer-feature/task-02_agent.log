{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0195gbZNy2Bo2vEkkHPjS1GT","type":"tool_result","content":"     1→package config\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"os\"\n     6→\t\"path/filepath\"\n     7→\n     8→\t\"gopkg.in/yaml.v3\"\n     9→)\n    10→\n    11→// Project represents a worktree project configuration\n    12→type Project struct {\n    13→\tName     string   `yaml:\"name\"`\n    14→\tPath     string   `yaml:\"path\"`\n    15→\tTags     []string `yaml:\"tags,omitempty\"`\n    16→\tCategory string   `yaml:\"category,omitempty\"`\n    17→}\n    18→\n    19→// Config represents the application configuration\n    20→type Config struct {\n    21→\tProjects   []Project `yaml:\"projects\"`\n    22→\tCategories []string  `yaml:\"categories,omitempty\"`\n    23→}\n    24→\n    25→// customConfigPath holds the custom config path if set via --config flag\n    26→var customConfigPath string\n    27→\n    28→// SetConfigPath sets a custom config path\n    29→func SetConfigPath(path string) {\n    30→\tcustomConfigPath = path\n    31→}\n    32→\n    33→// GetConfigPath returns the path to the config file (exported for use in cmd package)\n    34→func GetConfigPath() (string, error) {\n    35→\treturn getConfigPath()\n    36→}\n    37→\n    38→// getConfigPath returns the path to the config file\n    39→func getConfigPath() (string, error) {\n    40→\t// Use custom path if set\n    41→\tif customConfigPath != \"\" {\n    42→\t\treturn customConfigPath, nil\n    43→\t}\n    44→\n    45→\thome, err := os.UserHomeDir()\n    46→\tif err != nil {\n    47→\t\treturn \"\", fmt.Errorf(\"failed to get user home directory: %w\", err)\n    48→\t}\n    49→\treturn filepath.Join(home, \".config\", \"wt\", \"config.yaml\"), nil\n    50→}\n    51→\n    52→// getConfigDir returns the path to the config directory\n    53→func getConfigDir() (string, error) {\n    54→\thome, err := os.UserHomeDir()\n    55→\tif err != nil {\n    56→\t\treturn \"\", fmt.Errorf(\"failed to get user home directory: %w\", err)\n    57→\t}\n    58→\treturn filepath.Join(home, \".config\", \"wt\"), nil\n    59→}\n    60→\n    61→// InitConfig creates the config directory and a default config file if they don't exist\n    62→func InitConfig() error {\n    63→\tconfigDir, err := getConfigDir()\n    64→\tif err != nil {\n    65→\t\treturn err\n    66→\t}\n    67→\n    68→\t// Create config directory if it doesn't exist\n    69→\tif err := os.MkdirAll(configDir, 0755); err != nil {\n    70→\t\treturn fmt.Errorf(\"failed to create config directory: %w\", err)\n    71→\t}\n    72→\n    73→\tconfigPath, err := getConfigPath()\n    74→\tif err != nil {\n    75→\t\treturn err\n    76→\t}\n    77→\n    78→\t// Check if config file already exists\n    79→\tif _, err := os.Stat(configPath); err == nil {\n    80→\t\t// Config file already exists\n    81→\t\treturn nil\n    82→\t}\n    83→\n    84→\t// Create default config\n    85→\tdefaultConfig := Config{\n    86→\t\tProjects: []Project{},\n    87→\t}\n    88→\n    89→\treturn SaveConfig(&defaultConfig)\n    90→}\n    91→\n    92→// LoadConfig reads the config file and returns a Config struct\n    93→func LoadConfig() (*Config, error) {\n    94→\tconfigPath, err := getConfigPath()\n    95→\tif err != nil {\n    96→\t\treturn nil, err\n    97→\t}\n    98→\n    99→\t// Check if config file exists\n   100→\tif _, err := os.Stat(configPath); os.IsNotExist(err) {\n   101→\t\t// Initialize config if it doesn't exist\n   102→\t\tif err := InitConfig(); err != nil {\n   103→\t\t\treturn nil, fmt.Errorf(\"failed to initialize config: %w\", err)\n   104→\t\t}\n   105→\t}\n   106→\n   107→\t// Read config file\n   108→\tdata, err := os.ReadFile(configPath)\n   109→\tif err != nil {\n   110→\t\treturn nil, fmt.Errorf(\"failed to read config file: %w\", err)\n   111→\t}\n   112→\n   113→\t// Parse YAML\n   114→\tvar config Config\n   115→\tif err := yaml.Unmarshal(data, &config); err != nil {\n   116→\t\treturn nil, fmt.Errorf(\"failed to parse config file: %w\", err)\n   117→\t}\n   118→\n   119→\treturn &config, nil\n   120→}\n   121→\n   122→// SaveConfig writes the Config struct to the config file\n   123→func SaveConfig(config *Config) error {\n   124→\tconfigPath, err := getConfigPath()\n   125→\tif err != nil {\n   126→\t\treturn err\n   127→\t}\n   128→\n   129→\t// Marshal config to YAML\n   130→\tdata, err := yaml.Marshal(config)\n   131→\tif err != nil {\n   132→\t\treturn fmt.Errorf(\"failed to marshal config: %w\", err)\n   133→\t}\n   134→\n   135→\t// Write to file\n   136→\tif err := os.WriteFile(configPath, data, 0644); err != nil {\n   137→\t\treturn fmt.Errorf(\"failed to write config file: %w\", err)\n   138→\t}\n   139→\n   140→\treturn nil\n   141→}\n   142→\n   143→// FindProject finds a project by name in the config\n   144→func (c *Config) FindProject(name string) (*Project, error) {\n   145→\tfor i := range c.Projects {\n   146→\t\tif c.Projects[i].Name == name {\n   147→\t\t\treturn &c.Projects[i], nil\n   148→\t\t}\n   149→\t}\n   150→\treturn nil, fmt.Errorf(\"project '%s' not found\", name)\n   151→}\n   152→\n   153→// AddTags adds tags to a project if they don't already exist\n   154→func (p *Project) AddTags(tags ...string) bool {\n   155→\tmodified := false\n   156→\tfor _, tag := range tags {\n   157→\t\t// Check if tag already exists\n   158→\t\texists := false\n   159→\t\tfor _, t := range p.Tags {\n   160→\t\t\tif t == tag {\n   161→\t\t\t\texists = true\n   162→\t\t\t\tbreak\n   163→\t\t\t}\n   164→\t\t}\n   165→\t\tif !exists {\n   166→\t\t\tp.Tags = append(p.Tags, tag)\n   167→\t\t\tmodified = true\n   168→\t\t}\n   169→\t}\n   170→\treturn modified\n   171→}\n   172→\n   173→// RemoveTags removes tags from a project\n   174→func (p *Project) RemoveTags(tags ...string) bool {\n   175→\tmodified := false\n   176→\tfor _, tag := range tags {\n   177→\t\tfor i := 0; i < len(p.Tags); i++ {\n   178→\t\t\tif p.Tags[i] == tag {\n   179→\t\t\t\tp.Tags = append(p.Tags[:i], p.Tags[i+1:]...)\n   180→\t\t\t\ti--\n   181→\t\t\t\tmodified = true\n   182→\t\t\t}\n   183→\t\t}\n   184→\t}\n   185→\treturn modified\n   186→}\n   187→\n   188→// GetAllTags returns all unique tags across all projects\n   189→func (c *Config) GetAllTags() []string {\n   190→\ttagSet := make(map[string]bool)\n   191→\tfor _, p := range c.Projects {\n   192→\t\tfor _, tag := range p.Tags {\n   193→\t\t\ttagSet[tag] = true\n   194→\t\t}\n   195→\t}\n   196→\t\n   197→\ttags := make([]string, 0, len(tagSet))\n   198→\tfor tag := range tagSet {\n   199→\t\ttags = append(tags, tag)\n   200→\t}\n   201→\treturn tags\n   202→}\n   203→\n   204→// FilterProjectsByTag returns projects that have the specified tag\n   205→func (c *Config) FilterProjectsByTag(tag string) []Project {\n   206→\tvar filtered []Project\n   207→\tfor _, p := range c.Projects {\n   208→\t\tfor _, t := range p.Tags {\n   209→\t\t\tif t == tag {\n   210→\t\t\t\tfiltered = append(filtered, p)\n   211→\t\t\t\tbreak\n   212→\t\t\t}\n   213→\t\t}\n   214→\t}\n   215→\treturn filtered\n   216→}\n   217→\n   218→// AddCategory adds a category to the config's categories list if it doesn't already exist\n   219→func (c *Config) AddCategory(category string) bool {\n   220→\t// Check if category already exists\n   221→\tfor _, cat := range c.Categories {\n   222→\t\tif cat == category {\n   223→\t\t\treturn false\n   224→\t\t}\n   225→\t}\n   226→\tc.Categories = append(c.Categories, category)\n   227→\treturn true\n   228→}\n   229→\n   230→// SetProjectCategory sets the category for a project\n   231→func (p *Project) SetCategory(category string) {\n   232→\tp.Category = category\n   233→}\n   234→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01MvxPR8xBdFBVfRhQa6vbpw","session_id":"f24827ed-0cbe-4a2a-8fb5-850782d12279","uuid":"b87faeff-c16d-45aa-bf26-3fda07291ebd"}
